#!/usr/bin/env python3
"""cowork — multi-role CLI orchestration entry point.

Thin shim that dispatches to scripts/cowork.py. Run from a terminal:

    ./cowork           # full 3-step entry flow + scout
    ./cowork --check   # preflight dependency check only
"""

import os
import sys

_HERE = os.path.dirname(os.path.realpath(__file__))
_VENV_PY = os.path.join(_HERE, ".venv", "bin", "python")
if os.path.exists(_VENV_PY) and os.path.realpath(sys.executable) != os.path.realpath(_VENV_PY):
    os.execv(_VENV_PY, [_VENV_PY, os.path.realpath(__file__), *sys.argv[1:]])

sys.path.insert(0, os.path.join(_HERE, "scripts"))

import cowork  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(cowork.main())
